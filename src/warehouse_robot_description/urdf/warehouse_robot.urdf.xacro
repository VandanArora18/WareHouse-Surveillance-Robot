<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="warehouse_robot">

  <!--COLORS-->
  <material name="grey"><color rgba="0.6 0.6 0.6 1"/></material>
  <material name="blue"><color rgba="0.1 0.2 0.8 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>

  <!--ROOT-->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.10"/>
  </joint>

  <!--BASE-->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.10"/>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.10"/>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="8"/>
      <inertia ixx="0.12" iyy="0.2" izz="0.25"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <!-- <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>1</update_rate>
      <visualize>true</visualize>
      <topic>imu</topic>
  </sensor> -->

  <!--DRIVE WHEELS-->
  <xacro:macro name="wheel" params="name y">
    <link name="${name}_wheel_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.08" length="0.04"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.08" length="0.04"/></geometry>
      </collision>
      <inertial>
        <mass value="1"/>
        <inertia ixx="0.02" iyy="0.01" izz="0.02"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="-0.18 ${y} 0.08"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="left" y="0.18"/>
  <xacro:wheel name="right" y="-0.18"/>

  <!--CASTERS-->
  <xacro:macro name="caster" params="name x y">

    <link name="${name}_steer_link">
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_steer_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_steer_link"/>
      <origin xyz="${x} ${y} 0.08"/>
      <axis xyz="0 0 1"/>
    </joint>

    <link name="${name}_wheel_link">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.04" length="0.03"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.04" length="0.03"/></geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.002" iyy="0.001" izz="0.002"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${name}_steer_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="0 0 -0.04"/>
      <axis xyz="0 1 0"/>
    </joint>

  </xacro:macro>

  <xacro:caster name="front_left"  x="0.22" y="0.12"/>
  <xacro:caster name="front_right" x="0.22" y="-0.12"/>

  <!--ARM BASE-->
  <link name="arm_base">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.06 0.06 0.3"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.06 0.06 0.3"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.02" iyy="0.02" izz="0.02"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0.05 0 0.1"/>
  </joint>

  <!--LOWER ARM-->
  <link name="arm_link1">
    <visual>
      <origin xyz="0.1 0 0"/>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.1 0 0"/>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!--FIXED SHOULDER-->
  <joint name="shoulder_joint" type="revolute">
    <parent link="arm_base"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.32"/>   
    <axis xyz="0 1 0"/>
    <!--PREVENT DOWNWARD COLLISION-->
    <limit lower="0.0" upper="1.57" effort="20" velocity="1"/>
  </joint>

  <!--UPPER ARM-->
  <link name="arm_link2">
    <visual>
      <origin xyz="0.1 0 0"/>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.1 0 0"/>
      <geometry><box size="0.2 0.05 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <origin xyz="0.2 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="1.57" effort="15" velocity="1"/>
  </joint>

  <!--GRIPPER-->
  <link name="gripper">
    <visual>
      <geometry><box size="0.08 0.08 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.08 0.08 0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.005" iyy="0.005" izz="0.005"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="wrist_joint" type="fixed">
    <parent link="arm_link2"/>
    <child link="gripper"/>
    <origin xyz="0.2 0 0"/>
  </joint>

  <!--LIDAR-->

  <!--LIDAR LINK-->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.2 0 0.15"/>
  </joint>

  <!--IMU-->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.15"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <topic>imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <topic>scan</topic>

    <!-- Ignition Fortress lidar format (NOT the Gazebo Classic <ray> format) -->
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>

      <!-- Required so the bridge fills LaserScan.header.frame_id correctly -->
      <gz_frame_id>lidar_link</gz_frame_id>
    </sensor>
  </gazebo>
  
  <!-- ═══════════════════════════════════════════════════════
     CAMERA
═══════════════════════════════════════════════════════ -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" iyy="1e-5" izz="1e-5"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
  <!-- Front of chassis, top face, facing forward (+X) -->
    <origin xyz="0.25 0 0.15" rpy="0 0 0"/>
  </joint>

<!-- Camera optical frame (ROS convention: Z forward, X right, Y down) -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

<!-- Ignition camera sensor -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
      <gz_frame_id>camera_optical_link</gz_frame_id>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>15.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
    </sensor>
  </gazebo>

  <!--DIFF DRIVE-->
  <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_radius>0.08</wheel_radius>
      <topic>cmd_vel</topic>
    </plugin>
  </gazebo>

</robot>